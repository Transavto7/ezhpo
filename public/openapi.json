{
  "openapi": "3.0.3",
  "info": {
    "title": "ЭЖПО OpenAPI",
    "description": "Интеграция с 1С",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "https://test.ta-7.ru",
      "description": "Тестовый сервер"
    },
    {
      "url": "http://ezhpo.localhost",
      "description": "Сервер для разработки"
    }
  ],
  "tags": [
    {
      "name": "Компании"
    },
    {
      "name": "Отчеты"
    }
  ],
  "paths": {
    "/api/1c/v1/companies": {
      "get": {
        "operationId": "GetCompanies",
        "tags": [
          "Компании"
        ],
        "summary": "Список всех компаний.",
        "description": "Метод получения списка всех компаний.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetCompany200"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      },
      "post": {
        "operationId": "CreateCompany",
        "tags": [
          "Компании"
        ],
        "summary": "Добавление компании.",
        "description": "Метод добавления компании.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/createCompanyRequest"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/CreateCompany200"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/1c/v1/reports": {
      "post": {
        "operationId": "CreateReportJob",
        "tags": [
          "Отчеты"
        ],
        "summary": "Формирование отчета.",
        "description": "Метод запроса формирования отчета.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CreateReportJob200"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/1c/v1/{id}/reports": {
      "get": {
        "operationId": "getReport",
        "tags": [
          "Отчеты"
        ],
        "summary": "Получение отчета.",
        "description": "Метод получения отчета.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Идентификатор отчета"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/GetReport200"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Company": {
        "type": "object",
        "required": [
          "id",
          "hash_id",
          "name",
          "inn"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Идентификатор компании"
          },
          "hash_id": {
            "type": "string",
            "description": "Хэш-идентификатор компании"
          },
          "name": {
            "type": "string",
            "description": "Наименование компании"
          },
          "inn": {
            "type": "string",
            "description": "ИНН компании"
          }
        }
      }
    },
    "requestBodies": {
      "createCompanyRequest": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Unauthorized",
        "headers": {
          "WWW_Authenticate": {
            "schema": {
              "type": "string",
              "example": "Unauthorized"
            }
          }
        }
      },
      "GetCompany200": {
        "description": "JSON-массив со всеми компаниями",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Company"
              }
            }
          }
        }
      },
      "CreateCompany200": {
        "description": "Успешное добавление компании",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "id"
              ],
              "properties": {
                "id": {
                  "type": "integer",
                  "description": "Идентификатор созданной компании"
                }
              }
            }
          }
        }
      },
      "GetReport200": {
        "description": "Статус отчета и его содержимое, если он готов",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "description": "Идентификатор отчета"
                },
                "content": {
                  "type": "string",
                  "description": "Содержимое отчета",
                  "nullable": true
                }
              }
            }
          }
        }
      },
      "CreateReportJob200": {
        "description": "Статус отчета и его содержимое, если он готов",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "id"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Идентификатор отчета"
                }
              }
            }
          }
        }
      }
    }
  }
}
